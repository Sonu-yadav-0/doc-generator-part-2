<apex:page standardController="Quote" extensions="GN_QuoteTemplateController" renderAs="{!vfType}" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" showHeader="false">
    <head>
        <style type="text/css" media="print">
            @page {
                size: A4;
                margin-bottom: 28mm;
                margin-top: 36mm;
                margin-left: 13.5mm;
                margin-right: 13.5mm;
                @top-left {
                    content: element(headerLeft);
                    border-bottom: 2px solid {!darkShadeColor};
                }
                @top-right{
                    content: element(headerRight);
                    border-bottom: 2px solid {!darkShadeColor};
                }
                @bottom-center {
                    content: element(footer);
                }
            }
            @page :first {
                margin-bottom: 40mm;
                margin-top: -2mm;
                margin-left: -2mm;
                margin-right: -2mm;
                @top-left {
                }
                @top-right {
                }
                @bottom-center {
                    content: element(theGrid);
                }
            }
            body {
                font-family: Arial, 'Helvetica Neue', sans-serif;
                font-size: 11px;
                margin:0;
                padding:0;
            }
            div.headerLeft {
            text-align: left;
            padding: 10px;
            width: auto;
            overflow: hidden;
            height: 87px !important;
            position: running(headerLeft);
            }
            div.headerRight{
            padding: 10px;
            line-height: 2%;    
            width: auto;
            overflow: hidden;
            word-break: break-all;
            height: 87px !important; 
            position: running(headerRight);
            }
            div.Footer{
            display: block;
            text-align: center;
            margin-top: 10px;
            position: running(Footer);
            }
            div.coverPage_content_container{
                margin-top: 10%;
                margin-left: 7%;
                margin-right: 7%;
                color: #454545;
            }
            div.Godrej_Offer_Heading{
                font-size: 28px; !important;
            }
            div.Godrej_Main_Heading{
                font-size: 42px; !important;
            }
            div.dynamic_family_container{
                margin-top: 15%;
                margin-left: 7%;
                color: {!darkShadeColor};
                font-size: 33px; !important;
            }
            div.qrcode_image_data{
                display: block;
            }
            div.clearfix {
                clear: both;
            }
            .QuoteSection {
                page-break-before: always;
                margin-right: 14.5%;
            }
            .col {
                float: left;
            }
            .image1{
                 width: 70%;
            }
            .image2{
                 width: 30%;
            }
            .col1 {
                width:450px; 
                border-bottom: 1px solid #454545;
                text-align:center;
            }
            .col2 {
                width:50px; 
                text-align:center;
            }
            .col3 {
                width:100px; 
                text-align:center;
            }

        </style> 
    </head>
    <body>
        
        <header class="mainHeader">
            <div class="Header_Container" >
                <div class="headerLeft">
                    <apex:pageBlock rendered="{!leftHeaderContent != null}">
                        <div style="padding-top: 15px;">
                            <img src="{!leftHeaderContent}" height="{!headerLogoHeight}" width="{!headerLogoWidth}"  />  
                        </div>
                    </apex:pageBlock>
                    
                </div>
                <div style="padding-left: {!headerAddressLeftSpacing}px;" class="headerRight">
                       <apex:outputText escape="false" value="{!rightHeaderContent}" />                
                </div>
            </div>
        </header>
        
        <footer>
            <div class="Footer">
                <apex:pageBlock rendered="{!footerContent != null}">
                    <div style="padding-top: 15px; padding-bottom: 15px;">
                        <img src="{!footerContent}" height="62px" width="{!footerWidth}"/>
                    </div>
                </apex:pageBlock>
            </div>
        </footer>
        <!-- Cover Page -->
        <div height="850px" >
            <img src="{!showcaseImageNameUrl}" height="38%" width="100%" />
            <div class="coverPage_content_container" >
                <div class="Godrej_Offer_Heading" >
                    Offer document by
                </div>
                <div class="Godrej_Main_Heading">
                    <apex:outputText value="{!coverPageTitle}" escape="false"></apex:outputText> 
                </div>
            </div>
            <div class="dynamic_family_container">
                <apex:repeat value="{!productFamilyList}" var="eachFamily">
                    <apex:outputText value="{!eachFamily}"></apex:outputText><br/>
                </apex:repeat>
            </div>
        </div>
        <!-- Cover Page Footer -->
        <apex:panelGrid columns="3" id="theGrid" columnClasses="col1, col2, col3" style="padding-left: 60px; position: running(theGrid)" >
            <apex:outputText ></apex:outputText>
            <apex:outputText ></apex:outputText>
            <apex:outputText >
                <img src="{!bottomCoverImageUrl}" height="80px" width="160px"/>
            </apex:outputText>
        </apex:panelGrid>
        
        
        <div class="QuoteSection">
            
            <apex:repeat value="{!EachSectionDataToDisplay}" var="eachSectionContent" >
                <div style="text-align: {!eachSectionContent.sectionAlignment}; page-break-before: {!eachSectionContent.PageBreak};">
                    <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                    <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'Default' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                    </div>
                    <apex:pageBlock rendered="{!annexure1}">
                        <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                            <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'Technical Details' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                        </div>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Technical Details' , eachSectionContent.SectionType == 'Image')}">
                            <img src="{!eachSectionContent.imagesData.imageURL}" height="{!eachSectionContent.imagesData.imageHeight}" width="{!eachSectionContent.imagesData.imageWidth}" />
                        </apex:pageBlock>
                        
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Technical Details' , eachSectionContent.SectionType == 'Image With QRCode')}">
                            <div class="qrcode_image_data">
                                <div class="col image1">
                                    <img src="{!eachSectionContent.imageWithQRCodeData.normalImageURL}" height="{!eachSectionContent.imageWithQRCodeData.normalImageHeight}" width="{!eachSectionContent.imageWithQRCodeData.normalImageWidth}" />
                                </div>
                                <div class="col image2">
                                    <div style="margin-top:40%; margin-left: 5%;">
                                        <div style="width: 100px; margin-left: 28%;" >
                                            <apex:outputText value="{!eachSectionContent.imageWithQRCodeData.qrCodeImageText}" escape="false"></apex:outputText>
                                        </div>
                                        <div style="margin-left: 8%">
                                            <img src="{!eachSectionContent.imageWithQRCodeData.qrCodeImageURL}" height="100" width="100" />
                                        </div>
                                    </div>
                                </div>
                                <div class='clearfix'></div>
                            </div>
                            
                        </apex:pageBlock>
                        
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Technical Details' , eachSectionContent.SectionType == 'Image With Text')}">
                            <img src="{!eachSectionContent.imageWithText.imageURL}" height="{!eachSectionContent.imageWithText.imageHeight}" width="{!eachSectionContent.imageWithText.imageWidth}" />
                            <apex:outputText value="{!eachSectionContent.imageWithText.imageContent}" escape="false" style="padding-top: 15px;" />
                        </apex:pageBlock>
                        
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Technical Details' , eachSectionContent.SectionType == 'Product Specification')}">
                            <!-- Product Specification Table -->
                            <apex:variable value="#ffffff" var="mediumShadeColor" />
                            <apex:variable value="{!lightShadeColor}" var="lightShadeColor" />
                            <apex:variable value="{!1}" var="fullSection" />
                            <table style="width: 100%; border-left: 1px solid rgb(127,127,127); border-right: 1px solid rgb(127,127,127); border-top: 0.5px solid rgb(127,127,127); border-bottom: 0.5px solid rgb(127,127,127); border-collapse: collapse; -fs-table-paginate: paginate; border-spacing: 0px; margin-top: 30px;">
                                <apex:repeat value="{!eachSectionContent.eachRowWrapData}" var="eachRow" >
                                    <apex:variable value="{!1}" var="eachRowCount" />
                                    <apex:repeat value="{!eachRow.rowData}" var="eachRowData" >
                                        <tr class="border_bottom" style="height: {!eachSectionContent.psRowSpacing}; background-color: {!IF(mod(fullSection,2)==0, mediumShadeColor, lightShadeColor)}" >
                                            <apex:outputText rendered="{!IF(eachRowCount == 1, true , false)}">
                                                <td style="width: 22%; text-align: center; font-weight: 200; border-right: 1px solid rgb(127,127,127); border-top: 0.5px solid rgb(127,127,127); border-bottom: 0.5px solid rgb(127,127,127);" rowspan = "{!eachRow.rowData.size}">
                                                    {!eachRow.sectionName}
                                                </td>
                                            </apex:outputText>
                                                 <td style="width: 38%; text-align: left; font-weight: 200; border-top: 0.5px solid rgb(127,127,127); border-bottom: 0.5px solid rgb(127,127,127);">
                                                     <div style="padding-left: 4px;">
                                                         
                                                        <apex:outputText rendered="{!IF(eachRowData.isBold == True, true , false)}">
                                                            <b>{!eachRowData.drive}</b>
                                                        </apex:outputText>
                                                        <apex:outputText rendered="{!IF(eachRowData.isBold == False, true , false)}">
                                                            {!eachRowData.drive}
                                                        </apex:outputText>
                                                     </div>
                                                </td>
                                                <td style="width: 15%; text-align: center; font-weight: 200; border-top: 0.5px solid rgb(127,127,127); border-bottom: 0.5px solid rgb(127,127,127);">
                                                    <apex:outputText rendered="{!IF(eachRowData.isBold == True, true , false)}">
                                                            <b>{!eachRowData.measurement}</b>
                                                        </apex:outputText>
                                                        <apex:outputText rendered="{!IF(eachRowData.isBold == False, true , false)}">
                                                            {!eachRowData.measurement}
                                                        </apex:outputText>
                                                    
                                                </td>
                                                <td style="width: 25%; text-align: center; font-weight: 200; border-top: 0.5px solid rgb(127,127,127); border-bottom: 0.5px solid rgb(127,127,127);">
                                                    <apex:outputText rendered="{!IF(eachRowData.isBold == True, true , false)}">
                                                            <b>{!eachRowData.battery}</b>
                                                        </apex:outputText>
                                                        <apex:outputText rendered="{!IF(eachRowData.isBold == False, true , false)}">
                                                            {!eachRowData.battery}
                                                        </apex:outputText>
                                                </td>   
                                        </tr>
                                        <apex:variable value="{!eachRowCount+1}" var="eachRowCount" />
                                    </apex:repeat> 
                                    <apex:variable value="{!fullSection+1}" var="fullSection" />
                                </apex:repeat>
                            </table>
                            <apex:outputText escape="false" rendered="{!eachSectionContent.show_SI_For_Ps}">
                                <div style="border: 1px solid black; margin-top: 12px;" >
                                    {!ps_specialinstructions}
                                </div>
                            </apex:outputText>
                        </apex:pageBlock>
                    </apex:pageBlock>

                    <apex:pageBlock rendered="{!annexure2}">
                        <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                            <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'Product Benefits' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                        </div>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Product Benefits' , eachSectionContent.SectionType == 'Image')}">
                            <img src="{!eachSectionContent.imagesData.imageURL}" height="{!eachSectionContent.imagesData.imageHeight}" width="{!eachSectionContent.imagesData.imageWidth}" />
                        </apex:pageBlock>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Product Benefits' , eachSectionContent.SectionType == 'Image With Text')}">
                            <img src="{!eachSectionContent.imageWithText.imageURL}" height="{!eachSectionContent.imageWithText.imageHeight}" width="{!eachSectionContent.imageWithText.imageWidth}" />
                            <apex:outputText value="{!eachSectionContent.imageWithText.imageContent}" escape="false" style="padding-top: 15px;" />
                        </apex:pageBlock>
                        
                    </apex:pageBlock>

                    <apex:pageBlock rendered="{!annexure3}">
                        <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                            <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'Extended Warranty Plan' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                        </div>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Extended Warranty Plan' , eachSectionContent.SectionType == 'Image')}">
                            <img src="{!eachSectionContent.imagesData.imageURL}" height="{!eachSectionContent.imagesData.imageHeight}" width="{!eachSectionContent.imagesData.imageWidth}" />
                        </apex:pageBlock>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Extended Warranty Plan' , eachSectionContent.SectionType == 'Image With Text')}">
                            <img src="{!eachSectionContent.imageWithText.imageURL}" height="{!eachSectionContent.imageWithText.imageHeight}" width="{!eachSectionContent.imageWithText.imageWidth}" />
                            <apex:outputText value="{!eachSectionContent.imageWithText.imageContent}" escape="false" style="padding-top: 15px;" />
                        </apex:pageBlock>
                        
                    </apex:pageBlock>

                    <apex:pageBlock rendered="{!annexure4}">
                        <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                            <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'Optional Safety Accessories' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                        </div>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Optional Safety Accessories' , eachSectionContent.SectionType == 'Image')}">
                            <img src="{!eachSectionContent.imagesData.imageURL}" height="{!eachSectionContent.imagesData.imageHeight}" width="{!eachSectionContent.imagesData.imageWidth}" />
                        </apex:pageBlock>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Optional Safety Accessories' , eachSectionContent.SectionType == 'Image With Text')}">
                            <img src="{!eachSectionContent.imageWithText.imageURL}" height="{!eachSectionContent.imageWithText.imageHeight}" width="{!eachSectionContent.imageWithText.imageWidth}" />
                            <apex:outputText value="{!eachSectionContent.imageWithText.imageContent}" escape="false" style="padding-top: 15px;" />
                        </apex:pageBlock>
                        
                    </apex:pageBlock>

                    <apex:pageBlock rendered="{!annexure5}">
                        <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                            <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'Price Matrix & Commercial Terms' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                        </div>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'Price Matrix & Commercial Terms' , eachSectionContent.SectionType == 'Table')}">
                        <!-- Invoice Table -->
                            <apex:variable value="{!mediumShadeColor}" var="mediumShadeColor" />
                            <apex:variable value="{!lightShadeColor}" var="lightShadeColor" />
                            <table style="width: 100%; border: 1px solid rgb(127,127,127); border-collapse: collapse;">
                                <apex:variable value="{!1}" var="count" />
                                <apex:repeat value="{!eachSectionContent.invoiceTableData}" var="eachQliRow" >
                                    <tr class="invoice_table_row" >
                                        <apex:variable value="{!count+1}" var="count" />
                                        <apex:repeat value="{!eachQliRow}" var="eachQliColumn">
                                            <td class="invoice_table_cell" 
                                                style=" 
                                                       text-align: {!eachQliColumn.textAlignment};
                                                       padding-left: {!eachQliColumn.paddingleft}; 
                                                       font-weight: 200;
                                                       border-left: {!eachQliColumn.borderLeft};
                                                       border-top: {!eachQliColumn.borderTop};
                                                       border-right: {!eachQliColumn.borderRight};
                                                       border-bottom: {!eachQliColumn.borderBottom};
                                                       background-color: {!eachQliColumn.backgroundColor};
                                                       color: {!eachQliColumn.color};
                                                       width: {!eachQliColumn.columnWidth};
                                                       font-size: {!eachQliColumn.fontSize}">
                                                <apex:outputPanel rendered="{!if(eachQliColumn.isRupeeSymbol == True , true ,false)}">  
                                                    <div style="text-align: left;" >
                                                        <apex:image url="{!$Resource.RupeeSymbol}" width="10" height="10"/>{!eachQliColumn.headerLabel}
                                                    </div> 
                                                </apex:outputPanel>
                                                <apex:outputPanel rendered="{!if(eachQliColumn.isRupeeSymbol != True , true ,false)}">  
                                                    <div>
                                                        {!eachQliColumn.headerLabel}
                                                    </div> 
                                                </apex:outputPanel>
                                            </td>
                                        </apex:repeat>
                                    </tr>
                                </apex:repeat>
                            </table>

                            <div style="text-align: right; margin-top: 8px;">
                                <apex:pageBlock rendered="{!IF(freightAmount == '0', False , True)}" >
                                    <div>
                                        <spane style="padding-right: 20px;">Freight Charges</spane> {!freightAmount}
                                    </div>
                                </apex:pageBlock>
                                <apex:pageBlock rendered="{!IF(finalBasicAmount == '0', False, True)}" >
                                    <div>
                                        <spane style="padding-right: 20px;">Final Basic Amount</spane> {!finalBasicAmount}
                                    </div>
                                </apex:pageBlock>
                            </div>
                        </apex:pageBlock>
                        
                    </apex:pageBlock>
                    
                    <apex:pageBlock rendered="{!annexure6}">
                        <div style = "line-height : {!eachSectionContent.contentLineSpacing}">
                            <apex:outputText value="{!eachSectionContent.content}" escape="false" rendered="{!AND(eachSectionContent.annexureValue == 'General Terms and Conditions for Sale of Equipment' , OR(eachSectionContent.SectionType == 'Dynamic Text', eachSectionContent.SectionType == 'Text'))}" />
                        </div>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'General Terms and Conditions for Sale of Equipment' , eachSectionContent.SectionType == 'Image')}">
                            <img src="{!eachSectionContent.imagesData.imageURL}" height="{!eachSectionContent.imagesData.imageHeight}" width="{!eachSectionContent.imagesData.imageWidth}" />
                        </apex:pageBlock>
                        <apex:pageBlock rendered="{!AND(eachSectionContent.annexureValue == 'General Terms and Conditions for Sale of Equipment' , eachSectionContent.SectionType == 'Image With Text')}">
                            <img src="{!eachSectionContent.imageWithText.imageURL}" height="{!eachSectionContent.imageWithText.imageHeight}" width="{!eachSectionContent.imageWithText.imageWidth}" />
                            <apex:outputText value="{!eachSectionContent.imageWithText.imageContent}" escape="false" style="padding-top: 15px;" />
                        </apex:pageBlock>

                        
                    </apex:pageBlock>

                </div>
            </apex:repeat>
        </div>
    </body>
</apex:page>